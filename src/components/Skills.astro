---
import { skillGroups } from "../data/skills";
---

<section
  id="skills"
  class="relative py-24 px-6"
  style="background: var(--color-surface);"
>
  <!-- Top fade -->
  <div
    class="absolute top-0 left-0 right-0 h-16 pointer-events-none"
    style="background: linear-gradient(to bottom, var(--color-bg), var(--color-surface));"
  />

  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <p class="section-label mb-3">Skills</p>
      <h2
        class="text-4xl md:text-5xl font-black tracking-tight"
        style="color: var(--color-text);"
      >
        Tools & Technologies
      </h2>
    </div>

    <!-- Skill groups -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillGroups.map((group) => (
        <div class="glass p-6">
          <div class="flex items-center gap-3 mb-5">
            <span
              class="text-base font-bold font-mono"
              style="color: var(--color-primary);"
            >
              {group.icon}
            </span>
            <h3
              class="text-sm font-bold uppercase tracking-widest"
              style="color: var(--color-text);"
            >
              {group.category}
            </h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom fade -->
  <div
    class="absolute bottom-0 left-0 right-0 h-16 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, var(--color-bg));"
  />
</section>
