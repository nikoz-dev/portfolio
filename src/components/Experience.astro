---
import { experiences } from "../data/experience";
---

<section
  id="experience"
  class="relative py-24 px-6"
  style="background: var(--color-surface);"
>
  <!-- Top fade -->
  <div
    class="absolute top-0 left-0 right-0 h-16 pointer-events-none"
    style="background: linear-gradient(to bottom, var(--color-bg), var(--color-surface));"
    aria-hidden="true"
  ></div>

  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <p class="section-label mb-3">Experience</p>
      <h2
        class="text-4xl md:text-5xl font-black tracking-tight"
        style="color: var(--color-text);"
      >
        Where I've worked
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <div class="timeline-line"></div>
      <div class="space-y-8 pb-2">
        {experiences.map((exp, i) => (
          <div
            class="reveal relative ml-6 glass p-6 md:p-8"
            data-delay={String(i)}
          >
            <!-- Timeline dot -->
            <div
              class="exp-dot absolute -left-9 top-8 w-3 h-3 rounded-full border-2"
              style="background: var(--color-primary); border-color: var(--color-bg); box-shadow: 0 0 10px rgba(249,115,22,0.55);"
            ></div>

            <!-- Header row -->
            <div class="flex flex-wrap items-start justify-between gap-3 mb-5">
              <div>
                <h3 class="text-xl font-bold mb-1" style="color: var(--color-text);">{exp.role}</h3>
                <p class="text-sm font-semibold" style="color: var(--color-primary);">
                  {exp.company}
                  <span class="font-normal ml-2" style="color: var(--color-text-muted);">· {exp.location}</span>
                </p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                {exp.current && (
                  <span
                    class="text-xs px-2.5 py-1 rounded-full font-semibold"
                    style="background: rgba(249,115,22,0.12); color: var(--color-primary); border: 1px solid rgba(249,115,22,0.28);"
                  >
                    Current
                  </span>
                )}
                <span class="text-xs font-mono" style="color: var(--color-text-muted);">{exp.period}</span>
              </div>
            </div>

            <!-- Bullets -->
            <ul class="space-y-2.5 mb-6">
              {exp.bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <span
                    class="flex-shrink-0 mt-2 w-1 h-1 rounded-full"
                    style="background: var(--color-primary);"
                  ></span>
                  <span style="color: var(--color-text-muted);">{bullet}</span>
                </li>
              ))}
            </ul>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {exp.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div
    class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, var(--color-bg));"
    aria-hidden="true"
  ></div>
</section>
