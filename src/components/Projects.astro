---
import { Image } from "astro:assets";
import { projects } from "../data/projects";
---

<section
  id="projects"
  class="relative z-10 py-16 px-6"
  style="background: var(--color-bg); margin-top: -4rem;"
>
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <p class="section-label mb-3">Projects</p>
      <h2
        class="text-4xl md:text-5xl font-black tracking-tight"
        style="color: var(--color-text);"
      >
        What I've built
      </h2>
    </div>

    <!-- 2-col grid -->
    <div class="grid md:grid-cols-2 gap-5">
      {projects.map((project, i) => (
        <article
          class="reveal glass overflow-hidden flex flex-col"
          data-delay={String(i)}
          data-card-href={project.badge && project.links.github ? project.links.github : undefined}
        >
          <!-- Image header -->
          {project.images.length > 0 ? (
            <div class="proj-image-wrap">
              <Image
                src={project.images[0]}
                alt={`${project.title} screenshot`}
                densities={[1, 2]}
                class="proj-image"
                loading="lazy"
                decoding="async"
              />
            </div>
          ) : (
            <div class="proj-placeholder" aria-hidden="true">
              <span class="proj-placeholder-letter">
                {project.title.charAt(0)}
              </span>
            </div>
          )}

          <!-- Card body -->
          <div class="p-5 flex flex-col flex-grow">

            <!-- Type + action button -->
            <div class="flex items-center justify-between mb-3">
              <span class="section-label text-xs">{project.type}</span>

              {project.badge && project.links.github ? (
                /* Expandable repo button — hover reveals GitHub logo + "Repo" */
                <a
                  href={project.links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="proj-action-btn"
                  aria-label={`View ${project.title} on GitHub`}
                >
                  <!-- Arrow (default state, hidden on hover) -->
                  <svg class="btn-arrow-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <!-- GitHub (hover state, hidden by default) -->
                  <svg class="btn-gh-icon" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                  </svg>
                  <span class="btn-repo-text">Repo</span>
                </a>
              ) : !project.badge && !project.links.github && !project.links.live ? (
                /* Expanding "Docs coming soon" — non-interactive, no href */
                <div class="proj-coming-btn" aria-label="Documentation coming soon">
                  <!-- Arrow (default state, hidden on hover) -->
                  <svg class="btn-arrow-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <!-- Doc icon (hover state, hidden by default) -->
                  <svg class="btn-doc-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                  </svg>
                  <span class="btn-coming-text">Docs coming soon</span>
                </div>
              ) : (
                /* Static decorative button (fallback) */
                <div
                  class="w-7 h-7 rounded-full flex items-center justify-center"
                  style="background: rgba(249,115,22,0.1); color: var(--color-primary);"
                  aria-hidden="true"
                >
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
                    <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              )}
            </div>

            <!-- Title -->
            <h3 class="text-lg font-bold mb-2" style="color: var(--color-text);">{project.title}</h3>

            <!-- Description -->
            <p class="text-sm leading-relaxed mb-4 flex-grow" style="color: var(--color-text-muted);">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>

            <!-- Footer: badge OR links -->
            <div class="flex items-center gap-4 mt-auto">

              {/* Badge (e.g. "University Project") replaces all link buttons */}
              {project.badge ? (
                <span class="proj-badge">{project.badge}</span>
              ) : null}

              {!project.badge && project.links.github ? (
                <a
                  href={project.links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="proj-link inline-flex items-center gap-2 text-sm font-medium"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                  </svg>
                  Code
                </a>
              ) : null}

              {!project.badge && project.links.live ? (
                <a
                  href={project.links.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="proj-link inline-flex items-center gap-2 text-sm font-medium"
                >
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M5.5 2.5H2.5a1 1 0 00-1 1v8a1 1 0 001 1h8a1 1 0 001-1V8.5M8.5 1.5H12.5M12.5 1.5V5.5M12.5 1.5L6.5 7.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Live
                </a>
              ) : null}

              {!project.badge && !project.links.github && !project.links.live ? (
                <span class="text-xs" style="color: var(--color-text-muted);">Personal project</span>
              ) : null}

            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  // Mobile (touch / no-hover): tap anywhere on the card to open the repo
  document.querySelectorAll<HTMLElement>("[data-card-href]").forEach((card) => {
    if (window.matchMedia("(hover: none)").matches) {
      card.style.cursor = "pointer";
    }
    card.addEventListener("click", (e) => {
      if (!window.matchMedia("(hover: none)").matches) return;
      const target = e.target as HTMLElement;
      if (target.closest("a")) return; // let actual links handle themselves
      const href = card.dataset.cardHref;
      if (href) window.open(href, "_blank", "noopener,noreferrer");
    });
  });
</script>

<style>
  /* ── Image header ───────────────────────────────────── */
  .proj-image-wrap {
    width: 100%;
    aspect-ratio: 2.4 / 1;
    overflow: hidden;
    background: var(--color-surface);
  }
  .proj-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.4s ease;
  }
  article:hover .proj-image {
    transform: scale(1.02);
  }

  /* ── Gradient placeholder (no image) ───────────────── */
  .proj-placeholder {
    width: 100%;
    aspect-ratio: 2.4 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      rgba(249, 115, 22, 0.15) 0%,
      rgba(249, 115, 22, 0.04) 50%,
      rgba(249, 115, 22, 0.12) 100%
    );
    border-bottom: 1px solid rgba(249, 115, 22, 0.15);
  }
  .proj-placeholder-letter {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.4;
    user-select: none;
  }

  /* ── Regular link buttons ───────────────────────────── */
  .proj-link {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }
  .proj-link:hover { color: var(--color-primary); }

  /* ── Badge (e.g. "University Project") ─────────────── */
  .proj-badge {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  /* ── Expandable top-right action button ─────────────── */
  .proj-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 28px;
    width: 28px;
    padding: 0;
    border-radius: 9999px;
    background: rgba(249, 115, 22, 0.1);
    color: var(--color-primary);
    overflow: hidden;
    white-space: nowrap;
    text-decoration: none;
    flex-shrink: 0;
    transition:
      width     0.35s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s ease;
  }
  .proj-action-btn:hover {
    width: 76px;
    background: rgba(249, 115, 22, 0.18);
  }

  /* Arrow icon: visible by default, shrinks to 0 on hover */
  .btn-arrow-icon {
    flex-shrink: 0;
    width: 12px;
    overflow: hidden;
    transition: width 0.2s ease, opacity 0.15s ease;
    opacity: 1;
  }
  .proj-action-btn:hover .btn-arrow-icon,
  .proj-coming-btn:hover .btn-arrow-icon {
    width: 0;
    opacity: 0;
  }

  /* GitHub icon: hidden by default, expands on hover */
  .btn-gh-icon {
    flex-shrink: 0;
    width: 0;
    overflow: hidden;
    transition: width 0.2s ease 0.05s, opacity 0.15s ease 0.05s;
    opacity: 0;
  }
  .proj-action-btn:hover .btn-gh-icon {
    width: 12px;
    opacity: 1;
  }

  /* "Repo" text — slides in from the right */
  .btn-repo-text {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    margin-left: 0;
    transition:
      max-width   0.3s cubic-bezier(0.22, 1, 0.36, 1),
      opacity     0.2s ease 0.1s,
      margin-left 0.3s ease;
  }
  .proj-action-btn:hover .btn-repo-text {
    max-width: 36px;
    opacity: 1;
    margin-left: 5px;
  }

  /* ── "Docs coming soon" expanding pill (non-interactive) ── */
  .proj-coming-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 28px;
    width: 28px;
    padding: 0;
    border-radius: 9999px;
    background: rgba(249, 115, 22, 0.1);
    color: var(--color-primary);
    overflow: hidden;
    white-space: nowrap;
    flex-shrink: 0;
    cursor: default;
    transition:
      width     0.35s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s ease;
  }
  .proj-coming-btn:hover {
    width: 168px;
    background: rgba(249, 115, 22, 0.18);
  }

  /* Doc icon: hidden by default, expands on hover */
  .btn-doc-icon {
    flex-shrink: 0;
    width: 0;
    overflow: hidden;
    transition: width 0.2s ease 0.05s, opacity 0.15s ease 0.05s;
    opacity: 0;
  }
  .proj-coming-btn:hover .btn-doc-icon {
    width: 12px;
    opacity: 1;
  }

  /* "Docs coming soon" text — slides in */
  .btn-coming-text {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    margin-left: 0;
    transition:
      max-width   0.3s cubic-bezier(0.22, 1, 0.36, 1),
      opacity     0.2s ease 0.1s,
      margin-left 0.3s ease;
  }
  .proj-coming-btn:hover .btn-coming-text {
    max-width: 126px;
    opacity: 1;
    margin-left: 5px;
  }
</style>
