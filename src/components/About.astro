---
// About.astro — static section, no React island needed
---

<section id="about" class="relative z-10 py-24 px-6" style="background: var(--color-bg);">
  <!-- Overlap bridge from hero -->
  <div
    class="absolute top-0 left-0 right-0 h-24 pointer-events-none"
    style="background: linear-gradient(to bottom, var(--color-bg), transparent);"
  />

  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Left: bio text -->
      <div>
        <p class="section-label mb-4">About Me</p>
        <h2
          class="text-4xl md:text-5xl font-black tracking-tight mb-6 leading-tight"
          style="color: var(--color-text);"
        >
          Passionate about
          <span class="gradient-text"> building things</span>
        </h2>
        <div class="space-y-4 text-base leading-relaxed" style="color: var(--color-text-muted);">
          <p>
            I'm a <span style="color: var(--color-text);">Software Engineer</span> based in <span style="color: var(--color-text);">Cervignano del Friuli, Italy</span>  working at
            <span style="color: var(--color-text);">Tinexta Cyber</span> in Trieste.
            I specialize in building full-stack systems — from resilient <span style="color: var(--color-text);">Java</span> microservices
            and <span style="color: var(--color-text);">Python</span> data pipelines to interactive <span style="color: var(--color-text);">React</span> frontends and mobile apps.
          </p>
          <p>
            I care about clean, maintainable code and fast feedback loops. I actively use
            AI tooling, like  <span style="color: var(--color-text);">Claude Code</span> and <span style="color: var(--color-text);">OpenCode</span> to accelerate the development process without
            cutting corners on quality.
          </p>
          <p>
            When I'm not coding, I'm exploring new technologies, reading novels, or traveling to new countries.
          </p>
        </div>
      </div>

      <!-- Right: info cards -->
      <div class="grid grid-cols-1 gap-4">

        <!-- Location -->
        <div class="glass p-5 flex items-center gap-4">
          <span class="text-2xl">📍</span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest mb-0.5" style="color: var(--color-primary);">Location</p>
            <p class="text-sm font-medium" style="color: var(--color-text);">Cervignano del Friuli, Italy</p>
          </div>
        </div>

        <!-- Education -->
        <div class="glass p-5 flex items-center gap-4">
          <span class="text-2xl">🎓</span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest mb-0.5" style="color: var(--color-primary);">Education</p>
            <p class="text-sm font-medium" style="color: var(--color-text);">BSc Computer Science</p>
            <p class="text-xs" style="color: var(--color-text-muted);">University of Milan-Bicocca · 2020–2023</p>
          </div>
        </div>

        <!-- Languages -->
        <div class="glass p-5 flex items-center gap-4">
          <span class="text-2xl">🌍</span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest mb-0.5" style="color: var(--color-primary);">Languages</p>
            <p class="text-sm font-medium" style="color: var(--color-text);">English · Italian · Serbian</p>
          </div>
        </div>

        <!-- Status -->
        <div class="glass p-5 flex items-center gap-4">
          <span
            class="flex-shrink-0 w-3 h-3 rounded-full"
            style="background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.6);"
          />
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest mb-0.5" style="color: var(--color-primary);">Status</p>
            <p class="text-sm font-medium" style="color: var(--color-text);">Currently at Tinexta Cyber</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
