---
// Blobs: NO filter:blur, NO will-change, NO transform tricks.
// Pure radial-gradient backgrounds — the browser renders them as paint ops, zero compositor layers.
// A wider gradient stop spread mimics the soft-glow of a blurred circle perfectly.
---

<div class="blobs" aria-hidden="true">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<style>
  .blobs {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    border-radius: 9999px;
    animation: blob-breathe 9s ease-in-out infinite;
  }

  /* Wider gradient stops = same soft-glow look, no filter:blur needed */
  .blob-1 {
    width: 720px;
    height: 720px;
    top: -10%;
    left: -14%;
    background: radial-gradient(circle, rgba(249,115,22,0.20) 0%, rgba(249,115,22,0.07) 40%, transparent 68%);
    animation-delay: 0s;
  }

  .blob-2 {
    width: 560px;
    height: 560px;
    top: 20%;
    right: -10%;
    background: radial-gradient(circle, rgba(251,146,60,0.15) 0%, rgba(251,146,60,0.05) 42%, transparent 68%);
    animation-delay: -3s;
  }

  .blob-3 {
    width: 440px;
    height: 440px;
    bottom: 4%;
    left: 32%;
    background: radial-gradient(circle, rgba(234,88,12,0.13) 0%, rgba(234,88,12,0.04) 42%, transparent 68%);
    animation-delay: -6s;
  }

  /* Opacity-only — trivial for the browser, no layer promotion needed */
  @keyframes blob-breathe {
    0%, 100% { opacity: 0.75; }
    50%       { opacity: 1;    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob { animation: none; opacity: 0.9; }
  }
</style>
