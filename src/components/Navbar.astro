---
const navLinks = [
  { label: "About",      href: "#about"      },
  { label: "Experience", href: "#experience" },
  { label: "Projects",   href: "#projects"   },
  { label: "Skills",     href: "#skills"     },
  { label: "Contact",    href: "#contact"    },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a
      href="#hero"
      class="text-sm font-black tracking-widest uppercase text-primary hover:text-primary-light transition-colors duration-200"
      style="color: var(--color-primary);"
    >
      NZ
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            data-nav-link={href.slice(1)}
            class="nav-link text-sm font-medium text-text-muted hover:text-text transition-colors duration-200 relative py-1"
            style="color: var(--color-text-muted);"
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/Zjacic_Nikola_Resume.pdf"
          download
          class="resume-btn inline-flex items-center gap-1.5 text-xs font-semibold px-3.5 py-1.5 rounded-full tracking-wide"
        >
          Resume
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 2v8M5 7l3 3 3-3M2 13h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="hamburger"
      aria-label="Toggle menu"
      class="md:hidden flex flex-col gap-1.5 p-2 group"
    >
      <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300" style="background: var(--color-text);"></span>
      <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300" style="background: var(--color-text);"></span>
      <span class="hamburger-line block w-4 h-0.5 bg-text transition-all duration-300" style="background: var(--color-text);"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    style="background: rgba(10,10,10,0.98);"
  >
    <ul class="flex flex-col px-6 pb-6 gap-4 pt-2">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            data-mobile-nav-link={href.slice(1)}
            class="block text-sm font-medium py-2 transition-colors duration-200"
            style="color: var(--color-text-muted);"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar")!;
  const hamburger = document.getElementById("hamburger")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const navLinks = document.querySelectorAll("[data-nav-link]");
  const mobileLinks = document.querySelectorAll("[data-mobile-nav-link]");

  // ── Scroll solidify ──────────────────────────────────
  function updateNavbar() {
    if (window.scrollY > 50) {
      navbar.style.background = "rgba(10,10,10,0.95)";
      navbar.style.backdropFilter = "none";
      navbar.style.borderBottom = "1px solid rgba(249,115,22,0.1)";
    } else {
      navbar.style.background = "transparent";
      navbar.style.backdropFilter = "none";
      navbar.style.borderBottom = "none";
    }
  }
  window.addEventListener("scroll", updateNavbar, { passive: true });
  updateNavbar();

  // ── Mobile toggle ─────────────────────────────────────
  let menuOpen = false;
  hamburger.addEventListener("click", () => {
    menuOpen = !menuOpen;
    mobileMenu.style.maxHeight = menuOpen ? mobileMenu.scrollHeight + "px" : "0";
    const lines = hamburger.querySelectorAll(".hamburger-line");
    if (menuOpen) {
      (lines[0] as HTMLElement).style.transform = "translateY(8px) rotate(45deg)";
      (lines[1] as HTMLElement).style.opacity = "0";
      (lines[2] as HTMLElement).style.transform = "translateY(-8px) rotate(-45deg)";
      (lines[2] as HTMLElement).style.width = "20px";
    } else {
      (lines[0] as HTMLElement).style.transform = "";
      (lines[1] as HTMLElement).style.opacity = "";
      (lines[2] as HTMLElement).style.transform = "";
      (lines[2] as HTMLElement).style.width = "";
    }
  });

  // Close mobile menu on link click
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      menuOpen = false;
      mobileMenu.style.maxHeight = "0";
      const lines = hamburger.querySelectorAll(".hamburger-line");
      (lines[0] as HTMLElement).style.transform = "";
      (lines[1] as HTMLElement).style.opacity = "";
      (lines[2] as HTMLElement).style.transform = "";
      (lines[2] as HTMLElement).style.width = "";
    });
  });

  // ── Scroll-spy ────────────────────────────────────────
  const sections = ["about", "experience", "projects", "skills", "contact"];
  const activeColor = "var(--color-primary)";
  const mutedColor = "var(--color-text-muted)";

  function setActive(id: string) {
    navLinks.forEach((link) => {
      const el = link as HTMLElement;
      el.style.color = el.dataset.navLink === id ? activeColor : mutedColor;
    });
    mobileLinks.forEach((link) => {
      const el = link as HTMLElement;
      el.style.color = el.dataset.mobileNavLink === id ? activeColor : mutedColor;
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: "-40% 0px -55% 0px" }
  );

  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>

<style>
  /* Underline indicator on active nav link */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .resume-btn {
    border: 1px solid rgba(249,115,22,0.35);
    color: var(--color-primary);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .resume-btn:hover {
    background: rgba(249,115,22,0.08);
    border-color: var(--color-primary);
  }
</style>
